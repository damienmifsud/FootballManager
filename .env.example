# ============ MULTI-TEAM MODE (recommended) ============
# One JSON array defines every team. The code each parent types selects their
# team, so passwords MUST be unique across teams. calendarKey: openssl rand -hex 16
# Squadi IDs come from the FQ widget (DevTools) — see README.
TEAMS=[{"slug":"kangaroos-white","name":"Olympic FC U8 Kangaroos White","password":"white-team-code","calendarKey":"hex-string-1","squadi":{"competitionId":"1439","divisionId":"10661","teamId":110013}},{"slug":"second-team","name":"Olympic FC U8 Example","password":"different-code","calendarKey":"hex-string-2","squadi":{"competitionId":"1439","divisionId":"10661","teamId":110012}}]

# ============ LEGACY SINGLE-TEAM MODE ============
# Used only when TEAMS is not set — existing deployments keep working unchanged.
SITE_PASSWORD=
CALENDAR_KEY=
# SQUADI_COMPETITION_ID=1439
# SQUADI_DIVISION_ID=10661
# SQUADI_TEAM_ID=110013

# ============ SHARED ============
# Secret for the automated sync trigger (cron pinger: /api/sync?key=THIS).
# Syncs ALL configured teams in one call. Generate: openssl rand -hex 16
CRON_SECRET=change-me

# Production data store (required on Render/Vercel; one DB serves all teams,
# keyed per team). Without these, local JSON files are used (dev only).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Change-notification emails (optional, resend.com; covers all teams,
# subject is prefixed with the team name)
RESEND_API_KEY=
NOTIFY_EMAILS=
NOTIFY_FROM=Team Dashboard <onboarding@resend.dev>

# ============ PARENT / COACH LOGIN (Auth.js) ============
# Set AUTH_SECRET to switch ON account login (Google / Microsoft / magic-link).
# Until it's set, the site stays in team-code mode. Generate: openssl rand -hex 32
AUTH_SECRET=
# AUTH_URL is your site's URL, e.g. https://your-app.onrender.com (helps OAuth callbacks)
AUTH_URL=

# Magic-link (passwordless email) — needs a Resend account + verified from-address
AUTH_RESEND_KEY=
AUTH_EMAIL_FROM=Team Dashboard <login@yourdomain.com>

# Google — Google Cloud > APIs & Services > Credentials > OAuth client (Web)
# Authorised redirect URI: https://YOUR-DOMAIN/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Microsoft — Entra ID (Azure) > App registrations > new registration
# Redirect URI: https://YOUR-DOMAIN/api/auth/callback/microsoft-entra-id
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/common/v2.0

# Coach/manager access: add coach emails to each team in the TEAMS json:
#   "coachEmails":["byron@example.com","damien@example.com"]

# ============ "ASK" ASSISTANT (in-app Q&A over your PDFs + game data) ============
# Your Anthropic API key (server-side only; never exposed to the browser).
# Coaches upload PDFs in Settings; signed-in parents/coaches ask questions.
ANTHROPIC_API_KEY=
# Optional model override:
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
